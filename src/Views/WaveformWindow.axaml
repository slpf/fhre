<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:FH6RB"
        xmlns:vm="using:FH6RB.ViewModels"
        xmlns:ctl="using:FH6RB.Controls"
        xmlns:assets="clr-namespace:FH6RB.Assets"
        x:Class="FH6RB.Views.WaveformWindow"
        x:DataType="vm:EditWindowViewModel"
        Width="780" Height="765"
        MinWidth="560" MinHeight="765"
        MaxHeight="765"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Bg1}"
        Title="{x:Static assets:Str.TitleMarkers}">

    <Window.Styles>
        <Style Selector="TextBlock.mk">
            <Setter Property="Foreground" Value="{DynamicResource TxtMute}"/>
        </Style>
        <Style Selector="TextBlock.mk.hl">
            <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Margin="16,12,16,12">
            <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,8" ClipToBounds="True">
                <StackPanel Grid.Column="0">
                    <TextBlock  Text="{Binding FullName}" FontFamily="{DynamicResource MonoFont}"
                               FontSize="11" Foreground="{DynamicResource TxtFaint}" TextTrimming="CharacterEllipsis"
                               HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                </StackPanel>
                <Image Grid.Column="1" Source="avares://FH6RB/Assets/icons/icon_info.png" Width="12" Height="12"
                       HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip.Tip="{x:Static assets:Str.TipWaveHotkeys}"/>
                
            </Grid>
            
            <Border BorderBrush="{DynamicResource LineSoft}" BorderThickness="1" CornerRadius="3">
                <ctl:WaveformView x:Name="Wave" Height="170" Peaks="{Binding Peaks}" 
                                  Markers="{Binding AllMarkers}" SampleLength="{Binding SampleLength}"/>
            </Border>

            <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,12,0,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                    <Button Classes="wave_act" Width="32" Height="32" Focusable="False"
                            Click="OnPlay" ToolTip.Tip="{x:Static assets:Str.TipPlay}"
                            Background="{DynamicResource BgInput}">
                        <Image Source="avares://FH6RB/Assets/icons/icon_play.png" Width="24" Height="24"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button Classes="wave_act" Width="32" Height="32" Focusable="False"
                            Click="OnPause" ToolTip.Tip="{x:Static assets:Str.TipPause}"
                            Background="{DynamicResource BgInput}">
                        <Image Source="avares://FH6RB/Assets/icons/icon_pause.png" Width="24" Height="24"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button Classes="wave_act" Width="32" Height="32" Focusable="False"
                            Click="OnStop" ToolTip.Tip="{x:Static assets:Str.TipStop}"
                            Background="{DynamicResource BgInput}">
                        <Image Source="avares://FH6RB/Assets/icons/icon_stop.png" Width="22" Height="22"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button Classes="wave_act" Width="32" Height="32" Focusable="False"
                            Click="OnPlayLoop" ToolTip.Tip="{x:Static assets:Str.TipPlayLoop}"
                            Background="{DynamicResource BgInput}">
                        <Image Source="avares://FH6RB/Assets/icons/icon_loop.png" Width="20" Height="20"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
                <TextBlock Grid.Column="1" x:Name="TimeText" Text="{x:Static assets:Str.TimeZero}"
                           FontFamily="{DynamicResource MonoFont}" FontSize="11"
                           Foreground="{DynamicResource TxtMute}" TextAlignment="Right"
                           VerticalAlignment="Center" Margin="8,0,8,0"/>
                <Button Grid.Column="2" Classes="wave_act" Width="32" Height="32" Focusable="False"
                        Click="OnResetDefaults" ToolTip.Tip="{x:Static assets:Str.TipResetMarkers}"
                        Background="{DynamicResource BgInput}">
                    <Image Source="avares://FH6RB/Assets/icons/icon_replace.png" Width="26" Height="26"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </StackPanel>
        
        <Border Grid.Row="1" Margin="16,0,16,16" Background="{DynamicResource BgInput}"
                            BorderBrush="{DynamicResource BgDarkest}" BorderThickness="1" CornerRadius="8">
            <ScrollViewer Margin="16,16,16,16" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding Fields}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*,Auto,120,Auto" Margin="0,1"
                                                  Background="Transparent" Tag="{Binding}"
                                                  PointerEntered="OnFieldNameEntered"
                                                  PointerExited="OnFieldNameExited">
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Left" Text="{Binding Name}" VerticalAlignment="Center"
                                                               Classes="mk" Classes.hl="{Binding Highlighted}"
                                                               Background="Transparent" Tag="{Binding}"
                                                               PointerPressed="OnFieldNamePressed"
                                                               ToolTip.Tip="{Binding Description}"
                                                               FontSize="12"/>
                                                    <Image DockPanel.Dock="Left" Width="14" Height="14" Margin="8,0,0,0"
                                                           VerticalAlignment="Center" IsVisible="{Binding Locked}"
                                                           Source="avares://FH6RB/Assets/icons/icon_lock.png"/>
                                                    <Border VerticalAlignment="Center" Height="1" Margin="10,0"
                                                            IsHitTestVisible="False"
                                                            Background="{DynamicResource Line}"/>
                                                </DockPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0"
                                                            IsVisible="{Binding CanLoop}">
                                                    <Button Classes="mbutton" Width="18" Height="18" Margin="0,0,6,0"
                                                            Click="OnSuggestLoops" Tag="{Binding}"
                                                            ToolTip.Tip="{x:Static assets:Str.TipSuggestLoops}">
                                                        <Image Source="avares://FH6RB/Assets/icons/icon_pulse.png" Width="18" Height="18"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Button>
                                                    <Button Classes="mbutton" Width="18" Height="18"
                                                            Click="OnPlayMarkerLoop" Tag="{Binding}"
                                                            ToolTip.Tip="{x:Static assets:Str.TipPlayMarkerLoop}">
                                                        <Image Classes="loop" Width="18" Height="18"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Button>
                                                </StackPanel>
                                                <TextBox Grid.Column="2" Classes="field2" Tag="{Binding}"
                                                         IsEnabled="{Binding Editable}"
                                                         Text="{Binding SecondsText, Mode=TwoWay}"
                                                         Watermark="{x:Static assets:Str.WatermarkOff}"
                                                         ToolTip.Tip="{Binding ValueTip}"
                                                         ContextRequested="OnFieldContextRequested"
                                                         FontFamily="{DynamicResource MonoFont}" FontSize="12">
                                                    <TextBox.ContextFlyout>
                                                        <MenuFlyout>
                                                            <MenuItem Header="{x:Static assets:Str.MenuCut}" Click="OnFieldCut"/>
                                                            <MenuItem Header="{x:Static assets:Str.MenuCopy}" Click="OnFieldCopy"/>
                                                            <MenuItem Header="{x:Static assets:Str.MenuPaste}" Click="OnFieldPaste"/>
                                                            <Separator/>
                                                            <MenuItem Header="{x:Static assets:Str.MenuRevert}" Click="OnFieldRevert"/>
                                                            <MenuItem Header="{x:Static assets:Str.MenuReset}" Click="OnFieldReset"/>
                                                            <Separator/>
                                                            <MenuItem Header="{x:Static assets:Str.MenuConvertSeconds}" Tag="toSeconds" Click="OnFieldToSeconds"/>
                                                            <MenuItem Header="{x:Static assets:Str.MenuConvertSamples}" Tag="toSamples" Click="OnFieldToSamples"/>
                                                        </MenuFlyout>
                                                    </TextBox.ContextFlyout>
                                                </TextBox>
                                                <Button Grid.Column="3" Classes="mbutton" Width="14" Height="14" Margin="10,0,0,0"
                                                        Click="OnSetFromPlayhead" Tag="{Binding}"
                                                        IsEnabled="{Binding Editable}"
                                                        ToolTip.Tip="{x:Static assets:Str.TipSetPlayhead}">
                                                    <Image Classes="set" Width="14" Height="14"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource Bg2}"
                BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,1,0,0" Padding="20,13">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Classes="big" Click="OnCancel" Content="{x:Static assets:Str.BtnCancel}"/>
                <Button Classes="big primary" Click="OnSave" Content="{x:Static assets:Str.BtnSave}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="0" Grid.RowSpan="3" IsVisible="{Binding IsSuggesting}"
                Background="#D8161719">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                <Image Source="avares://FH6RB/Assets/icons/icon_processing.png" Width="56" Height="56"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       RenderTransformOrigin="50%,50%" Classes.spin="{Binding IsSuggesting}"/>
                <TextBlock Text="{x:Static assets:Str.StatusSuggesting}" Foreground="{DynamicResource Header}"
                           FontSize="14" HorizontalAlignment="Center" TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
