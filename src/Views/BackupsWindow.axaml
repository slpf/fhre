<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:FH6RB"
        xmlns:vm="using:FH6RB.ViewModels"
        xmlns:assets="clr-namespace:FH6RB.Assets"
        x:Class="FH6RB.Views.BackupsWindow"
        x:DataType="vm:BackupsViewModel"
        Width="560" Height="560"
        MinWidth="440" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Bg1}"
        Title="{x:Static assets:Str.TitleBackups}">

    <Grid RowDefinitions="*,Auto">
        <Panel Grid.Row="0">
            <TextBlock Text="{x:Static assets:Str.BackupEmpty}" IsVisible="{Binding !HasItems}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{DynamicResource TxtMute}" FontSize="13"/>

            <ScrollViewer Margin="16" IsVisible="{Binding HasItems}"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:BackupRow">
                            <Border Background="{DynamicResource BgInput}" BorderBrush="{DynamicResource BgDarkest}"
                                    BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Header}" FontSize="14"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Info}" Foreground="{DynamicResource TxtMute}"
                                                   FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Meta}" Foreground="{DynamicResource TxtMute}"
                                                   FontSize="11"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                                VerticalAlignment="Center" Margin="12,0,0,0">
                                        <Button Classes="big" Click="OnRestore" Tag="{Binding}"
                                                IsVisible="{Binding CanRestore}"
                                                Content="{x:Static assets:Str.BtnRestore}"/>
                                        <Button Classes="big" Click="OnDelete" Tag="{Binding}"
                                                Content="{x:Static assets:Str.BtnDelete}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Panel>

        <Border Grid.Row="1" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource LineSoft}"
                BorderThickness="0,1,0,0" Padding="20,13">
            <Button Classes="big" HorizontalAlignment="Right" Click="OnClose"
                    Content="{x:Static assets:Str.BtnClose}"/>
        </Border>
    </Grid>
</Window>
