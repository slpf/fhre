<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:FH6RB"
        xmlns:assets="clr-namespace:FH6RB.Assets"
        x:Class="FH6RB.Views.InputDialog"
        Width="440"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Bg1}"
        SizeToContent="Height"
        Title="{x:Static assets:Str.BackupNameTitle}">
    <Grid RowDefinitions="*,Auto">
        <StackPanel Margin="20" Spacing="12">
            <TextBox x:Name="Input" Classes="field2" FontSize="13"/>
        </StackPanel>
        <Border Grid.Row="1" Background="{DynamicResource Bg2}"
                BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,1,0,0" Padding="20,13">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Classes="big" Click="OnCancel" Content="{x:Static assets:Str.BtnCancel}"/>
                <Button Classes="big primary" Click="OnOk" Content="{x:Static assets:Str.BtnSave}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
